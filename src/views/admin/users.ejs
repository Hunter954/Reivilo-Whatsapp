<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Contatos</h1><p>Leads e participantes da REIVILO.</p></div></header>
<form class="filters" method="get"><input name="q" value="<%= q %>" placeholder="Telefone ou WhatsApp"><select name="status"><option value="">Todos os status</option><% ['not_started','checkout_created','approved','checkout_error'].forEach(s=>{ %><option value="<%= s %>" <%= status===s?'selected':'' %>><%= s %></option><% }) %></select><button>Filtrar</button></form>
<section class="panel"><table><thead><tr><th>Contato</th><th>Lead</th><th>Pagamento</th><th>Datas</th><th>Ações</th></tr></thead><tbody><% users.forEach(u=>{ %><tr><td><strong><%= formatPhone(u) %></strong><br><small><%= u.whatsapp_jid %></small></td><td><%= u.lead_status %><br><small><%= u.onboarding_step %></small></td><td><span class="pill"><%= u.payment_status %></span></td><td><small>Criado: <%= new Date(u.created_at).toLocaleString('pt-BR') %><% if(u.paid_at){ %><br>Pago: <%= new Date(u.paid_at).toLocaleString('pt-BR') %><% } %></small></td><td><form class="stacked" method="post" action="/admin/users/<%= u.id %>/send"><input type="hidden" name="returnTo" value="/admin/users"><textarea name="message" placeholder="Mensagem manual"></textarea><button>Enviar</button></form><% if(u.payment_status!=='approved'){ %><form method="post" action="/admin/users/<%= u.id %>/mark-paid"><button class="primary">Marcar pago</button></form><% } %></td></tr><% }) %></tbody></table></section><%- include('../partials/admin-footer') %>
