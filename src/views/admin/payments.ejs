<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Pagamentos</h1><p>Histórico recebido do Mercado Pago.</p></div></header><section class="panel"><table><thead><tr><th>ID</th><th>Contato</th><th>Status</th><th>Valor</th><th>Atualização</th></tr></thead><tbody><% payments.forEach(p=>{ %><tr><td><small><%= p.provider_payment_id||'-' %></small></td><td><%= formatPhone(p) %></td><td><span class="pill"><%= p.status %></span></td><td>R$ <%= (p.amount_cents/100).toFixed(2).replace('.',',') %></td><td><%= new Date(p.updated_at).toLocaleString('pt-BR') %></td></tr><% }) %></tbody></table></section><%- include('../partials/admin-footer') %>
