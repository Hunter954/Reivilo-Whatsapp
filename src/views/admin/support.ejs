<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Atendimento</h1><p>Contatos que escolheram falar com um atendente.</p></div></header><section class="panel"><table><thead><tr><th>Contato</th><th>Solicitado</th><th>Enviar resposta</th></tr></thead><tbody><% users.forEach(u=>{ %><tr><td><%= formatPhone(u) %></td><td><%= new Date(u.support_requested_at).toLocaleString('pt-BR') %></td><td><form class="stacked" method="post" action="/admin/users/<%= u.id %>/send"><input type="hidden" name="returnTo" value="/admin/support"><textarea name="message"></textarea><button>Responder</button></form></td></tr><% }) %></tbody></table></section><%- include('../partials/admin-footer') %>
