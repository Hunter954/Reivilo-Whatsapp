<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Configurações</h1><p>Dados salvos no PostgreSQL, sem depender de várias variáveis no Railway.</p></div></header><% if(saved){ %><div class="alert success">Configurações salvas.</div><% } %><div class="panel narrow"><p><strong>Domínio detectado:</strong> <%= publicBaseUrl || 'Ainda não detectado' %></p><p><strong>Mercado Pago:</strong> <%= hasMercadoPago ? 'Token configurado' : 'Token ausente no Railway' %></p><form method="post" class="stacked"><label>Usuário do painel<input name="admin_user" value="<%= settings.admin_user %>" required></label><label>Nova senha<input type="password" name="new_password" minlength="8" placeholder="Deixe vazio para manter"></label><label>Nome do produto<input name="product_name" value="<%= settings.product_name %>" required></label><label>Valor<input name="price_brl" value="<%= settings.price_brl %>" required></label><label>Site<input name="site_url" value="<%= settings.site_url %>"></label><label>ID do grupo<input name="group_jid" value="<%= settings.group_jid %>" placeholder="120363...@g.us"></label><label>Link do grupo<input name="group_invite_link" value="<%= settings.group_invite_link %>"></label><label>Mensagem de boas-vindas<textarea name="welcome_message" rows="6"><%= settings.welcome_message %></textarea></label><label>Mensagem “Saber mais”<textarea name="about_message" rows="6"><%= settings.about_message %></textarea></label><label>Mensagem antes do checkout<textarea name="checkout_intro" rows="5"><%= settings.checkout_intro %></textarea></label><label>Mensagem do atendimento<textarea name="support_message" rows="5"><%= settings.support_message %></textarea></label><button class="primary" type="submit">Salvar configurações</button></form></div><%- include('../partials/admin-footer') %>
