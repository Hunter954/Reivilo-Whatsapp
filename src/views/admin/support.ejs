<%- include('../partials/admin-header') %>
<header class="page-header support-page-header">
  <div>
    <h1>Central de atendimento</h1>
    <p>Atenda vários contatos em uma única tela, como em um aplicativo de mensagens.</p>
  </div>
  <span class="status <%= botReady ? 'ok' : 'warn' %>" id="waStatus"><%= botReady ? 'WhatsApp conectado' : 'WhatsApp desconectado' %></span>
</header>

<section class="support-shell" data-selected-id="<%= selected?.id || '' %>">
  <aside class="support-sidebar">
    <div class="support-sidebar-head">
      <div>
        <span class="eyebrow">Atendimentos</span>
        <strong>Conversas</strong>
      </div>
      <span class="support-count"><%= conversations.length %></span>
    </div>

    <div class="support-search-wrap">
      <span>⌕</span>
      <input id="contactSearch" placeholder="Buscar nome ou telefone..." autocomplete="off">
    </div>

    <div class="support-filter-tabs">
      <button type="button" class="support-filter active" data-filter="all">Todos</button>
      <button type="button" class="support-filter" data-filter="open">Abertos</button>
      <button type="button" class="support-filter" data-filter="closed">Encerrados</button>
    </div>

    <div id="conversationList" class="conversation-list">
      <% if (!conversations.length) { %>
        <div class="empty-state">Nenhum atendimento solicitado.</div>
      <% } %>
      <% conversations.forEach(u => { %>
        <button type="button"
          class="conversation-item <%= selected?.id===u.id ? 'active' : '' %>"
          data-user-id="<%= u.id %>"
          data-status="<%= u.support_status || 'closed' %>"
          data-search="<%= ((u.name || '') + ' ' + formatPhone(u)).toLowerCase() %>">
          <span class="avatar"><%= (u.name || formatPhone(u) || '?').charAt(0).toUpperCase() %></span>
          <span class="conversation-summary">
            <span class="conversation-top">
              <strong><%= u.name || formatPhone(u) %></strong>
              <small><%= new Date(u.support_last_message_at || u.support_requested_at || u.last_interaction_at).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %></small>
            </span>
            <span class="conversation-bottom">
              <span><%= u.last_direction==='out' ? 'Você: ' : '' %><%= (u.last_message || 'Atendimento solicitado').slice(0,58) %></span>
              <% if(Number(u.support_unread_count||0)>0){ %><b class="unread"><%= u.support_unread_count %></b><% } %>
            </span>
          </span>
        </button>
      <% }) %>
    </div>
  </aside>

  <section class="support-chat" id="supportChatPane">
    <div id="chatEmpty" class="no-chat <%= selected ? 'hidden' : '' %>">
      <div class="no-chat-icon">✦</div>
      <strong>Selecione um atendimento</strong>
      <span>Escolha um contato à esquerda para visualizar a conversa.</span>
    </div>

    <div id="chatContent" class="chat-content <%= selected ? '' : 'hidden' %>">
      <header class="chat-header">
        <div class="chat-person">
          <span class="avatar" id="chatAvatar"><%= selected ? (selected.name || formatPhone(selected) || '?').charAt(0).toUpperCase() : '?' %></span>
          <div>
            <strong id="chatName"><%= selected ? (selected.name || formatPhone(selected)) : '' %></strong>
            <small><span id="chatPhone"><%= selected ? formatPhone(selected) : '' %></span> · <span id="supportState"><%= selected?.support_status==='open' ? 'Atendimento aberto' : 'Atendimento encerrado' %></span></small>
          </div>
        </div>
        <div class="chat-actions">
          <button type="button" id="reopenButton" class="secondary <%= selected?.support_status==='open' ? 'hidden' : '' %>">Reabrir</button>
          <button type="button" id="closeButton" class="danger <%= selected?.support_status==='open' ? '' : 'hidden' %>">Encerrar</button>
        </div>
      </header>

      <div id="messageArea" class="message-area">
        <% (messages || []).forEach(m => { %>
          <div class="message-row <%= m.direction==='out' ? 'out' : 'in' %>" data-message-id="<%= m.id %>">
            <div class="message-bubble">
              <div><%= m.body || '[mensagem sem texto]' %></div>
              <small><%= new Date(m.created_at).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %></small>
            </div>
          </div>
        <% }) %>
      </div>

      <form id="replyForm" class="chat-compose <%= selected?.support_status==='open' ? '' : 'disabled' %>">
        <textarea id="replyMessage" rows="1" placeholder="<%= selected?.support_status==='open' ? 'Digite uma mensagem...' : 'Atendimento encerrado. Reabra para responder.' %>" <%= selected?.support_status==='open' ? '' : 'disabled' %>></textarea>
        <button class="send-message-button" id="sendButton" title="Enviar" <%= selected?.support_status==='open' ? '' : 'disabled' %>>➤</button>
      </form>
    </div>
  </section>

  <aside class="support-details" id="supportDetails">
    <div class="details-empty <%= selected ? 'hidden' : '' %>" id="detailsEmpty">Os detalhes do contato aparecerão aqui.</div>
    <div id="detailsContent" class="<%= selected ? '' : 'hidden' %>">
      <div class="details-profile">
        <span class="avatar large" id="detailsAvatar"><%= selected ? (selected.name || formatPhone(selected) || '?').charAt(0).toUpperCase() : '?' %></span>
        <strong id="detailsName"><%= selected ? (selected.name || formatPhone(selected)) : '' %></strong>
        <span id="detailsPhone"><%= selected ? formatPhone(selected) : '' %></span>
        <span class="details-status <%= selected?.support_status==='open' ? 'open' : 'closed' %>" id="detailsStatus"><%= selected?.support_status==='open' ? 'Atendimento aberto' : 'Atendimento encerrado' %></span>
      </div>
      <div class="details-card">
        <span>Origem</span>
        <strong>WhatsApp REIVILO</strong>
      </div>
      <div class="details-card">
        <span>Regra do bot</span>
        <strong id="botRule"><%= selected?.support_status==='open' ? 'Pausado durante o atendimento' : 'Menu automático liberado' %></strong>
      </div>
      <div class="details-note">
        Enquanto o atendimento estiver aberto, nenhuma opção automática será enviada ao cliente. O menu volta apenas depois do encerramento.
      </div>
    </div>
  </aside>
</section>

<script>
(() => {
  const conversations = <%- JSON.stringify(conversations.map(u => ({
    id: u.id,
    name: u.name || formatPhone(u),
    phone: formatPhone(u),
    status: u.support_status || 'closed'
  }))) %>;

  const list = document.getElementById('conversationList');
  const area = document.getElementById('messageArea');
  const form = document.getElementById('replyForm');
  const textarea = document.getElementById('replyMessage');
  const closeButton = document.getElementById('closeButton');
  const reopenButton = document.getElementById('reopenButton');
  let activeUserId = Number(document.querySelector('.support-shell').dataset.selectedId || 0);
  let lastIds = new Set(Array.from(area.querySelectorAll('[data-message-id]')).map(el => String(el.dataset.messageId)));
  let supportOpen = <%= selected?.support_status === 'open' ? 'true' : 'false' %>;
  let activeFilter = 'all';

  const escapeHtml = value => String(value || '').replace(/[&<>'"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
  const scrollBottom = () => { area.scrollTop = area.scrollHeight; };

  function currentConversation() {
    return conversations.find(item => Number(item.id) === Number(activeUserId));
  }

  function updateProfile(user) {
    const name = user.name || user.display_phone || user.phone || 'Contato';
    const phone = user.display_phone || user.phone || '';
    const initial = name.charAt(0).toUpperCase();
    ['chatAvatar','detailsAvatar'].forEach(id => document.getElementById(id).textContent = initial);
    ['chatName','detailsName'].forEach(id => document.getElementById(id).textContent = name);
    document.getElementById('chatPhone').textContent = phone;
    document.getElementById('detailsPhone').textContent = phone;
    document.getElementById('chatEmpty').classList.add('hidden');
    document.getElementById('chatContent').classList.remove('hidden');
    document.getElementById('detailsEmpty').classList.add('hidden');
    document.getElementById('detailsContent').classList.remove('hidden');
  }

  function addMessage(m) {
    if (lastIds.has(String(m.id))) return;
    lastIds.add(String(m.id));
    const date = new Date(m.created_at);
    area.insertAdjacentHTML('beforeend', `<div class="message-row ${m.direction === 'out' ? 'out' : 'in'}" data-message-id="${m.id}"><div class="message-bubble"><div>${escapeHtml(m.body || '[mensagem sem texto]').replace(/\n/g,'<br>')}</div><small>${date.toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})}</small></div></div>`);
  }

  function setOpen(open) {
    supportOpen = open;
    document.getElementById('supportState').textContent = open ? 'Atendimento aberto' : 'Atendimento encerrado';
    document.getElementById('detailsStatus').textContent = open ? 'Atendimento aberto' : 'Atendimento encerrado';
    document.getElementById('detailsStatus').className = `details-status ${open ? 'open' : 'closed'}`;
    document.getElementById('botRule').textContent = open ? 'Pausado durante o atendimento' : 'Menu automático liberado';
    closeButton.classList.toggle('hidden', !open);
    reopenButton.classList.toggle('hidden', open);
    textarea.disabled = !open;
    document.getElementById('sendButton').disabled = !open;
    textarea.placeholder = open ? 'Digite uma mensagem...' : 'Atendimento encerrado. Reabra para responder.';
    form.classList.toggle('disabled', !open);
    const item = document.querySelector(`.conversation-item[data-user-id="${activeUserId}"]`);
    if (item) item.dataset.status = open ? 'open' : 'closed';
  }

  async function loadConversation(userId, pushState = true) {
    activeUserId = Number(userId);
    document.querySelectorAll('.conversation-item').forEach(item => item.classList.toggle('active', Number(item.dataset.userId) === activeUserId));
    const response = await fetch(`/admin/support/api/${activeUserId}/messages`, {headers:{'Accept':'application/json'}});
    if (!response.ok) return;
    const data = await response.json();
    area.innerHTML = '';
    lastIds = new Set();
    updateProfile(data.user);
    data.messages.forEach(addMessage);
    setOpen(data.user.support_status === 'open');
    const badge = document.querySelector(`.conversation-item[data-user-id="${activeUserId}"] .unread`);
    if (badge) badge.remove();
    scrollBottom();
    if (pushState) history.replaceState({}, '', `/admin/support?user=${activeUserId}`);
  }

  async function refreshMessages() {
    if (!activeUserId) return;
    try {
      const response = await fetch(`/admin/support/api/${activeUserId}/messages`, {headers:{'Accept':'application/json'}});
      if (!response.ok) return;
      const data = await response.json();
      data.messages.forEach(addMessage);
      setOpen(data.user.support_status === 'open');
      scrollBottom();
    } catch (_) {}
  }

  list.addEventListener('click', event => {
    const item = event.target.closest('.conversation-item');
    if (!item) return;
    loadConversation(item.dataset.userId);
  });

  form.addEventListener('submit', async event => {
    event.preventDefault();
    const message = textarea.value.trim();
    if (!message || !supportOpen || !activeUserId) return;
    const button = document.getElementById('sendButton');
    button.disabled = true;
    try {
      const response = await fetch(`/admin/support/${activeUserId}/reply`, {method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({message})});
      const data = await response.json();
      if (!response.ok) throw new Error(data.error || 'Erro ao enviar.');
      textarea.value='';
      await refreshMessages();
    } catch (error) {
      alert(error.message);
    } finally {
      button.disabled = false;
      textarea.focus();
    }
  });

  textarea.addEventListener('keydown', event => {
    if (event.key === 'Enter' && !event.shiftKey) {
      event.preventDefault();
      form.requestSubmit();
    }
  });

  closeButton.addEventListener('click', async () => {
    if (!activeUserId) return;
    const message = prompt('Mensagem de encerramento:', 'Atendimento encerrado. Sempre que precisar, envie MENU para voltar às opções da REIVILO.');
    if (message === null) return;
    const response = await fetch(`/admin/support/${activeUserId}/close`, {method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({message})});
    if (!response.ok) return alert('Não foi possível encerrar.');
    await refreshMessages();
  });

  reopenButton.addEventListener('click', async () => {
    if (!activeUserId) return;
    const response = await fetch(`/admin/support/${activeUserId}/reopen`, {method:'POST',headers:{'Accept':'application/json'}});
    if (!response.ok) return alert('Não foi possível reabrir.');
    setOpen(true);
    textarea.focus();
  });

  function applyFilters() {
    const q = document.getElementById('contactSearch').value.toLowerCase().trim();
    document.querySelectorAll('.conversation-item').forEach(item => {
      const matchesText = item.dataset.search.includes(q);
      const matchesStatus = activeFilter === 'all' || item.dataset.status === activeFilter;
      item.style.display = matchesText && matchesStatus ? '' : 'none';
    });
  }

  document.getElementById('contactSearch').addEventListener('input', applyFilters);
  document.querySelectorAll('.support-filter').forEach(button => button.addEventListener('click', () => {
    activeFilter = button.dataset.filter;
    document.querySelectorAll('.support-filter').forEach(item => item.classList.toggle('active', item === button));
    applyFilters();
  }));

  scrollBottom();
  setInterval(refreshMessages, 3500);
})();
</script>
<%- include('../partials/admin-footer') %>
